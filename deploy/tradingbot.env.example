# Environment for the tradingbot systemd service.
# Copy to deploy/tradingbot.env and edit. All values are OPTIONAL for a
# loopback dry run.

# Only needed if you expose the API beyond loopback (the server refuses to
# start on a non-loopback host without this).
# TRADINGBOT_API_TOKEN=replace-with-a-long-random-token

# LIVE trading only — NOT needed for a dry run (dry run uses public market data).
# MEXC_API_KEY=
# MEXC_API_SECRET=

# Override the database location (defaults to backend/tradingbot.db).
# TRADINGBOT_DATABASE_URL=sqlite+aiosqlite:////opt/tradingbot/backend/tradingbot.db
