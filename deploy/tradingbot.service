[Unit]
Description=TradingBot backend (dry-run)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=tradingbot
Group=tradingbot
# Adjust to where you cloned the repo.
WorkingDirectory=/opt/tradingbot/backend
EnvironmentFile=-/opt/tradingbot/deploy/tradingbot.env
# Fail fast with a readable journal message if the venv/uvicorn/packages are
# missing, instead of an opaque status=203/EXEC from a non-existent ExecStart.
ExecStartPre=/opt/tradingbot/deploy/validate_deployment.sh --quiet
ExecStart=/opt/tradingbot/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000

# Auto-restart on crash; combined with resume_bots_on_startup this gives a
# continuous run. SIGTERM triggers the FastAPI lifespan shutdown, which saves
# bot state and flushes a final DB backup — give it time to finish.
Restart=always
RestartSec=5
TimeoutStopSec=30

StandardOutput=journal
StandardError=journal
SyslogIdentifier=tradingbot

[Install]
WantedBy=multi-user.target
