# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/
*.egg-info/
.eggs/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing/Screenshots
.playwright-mcp/

# Databases — including SQLite WAL/SHM sidecars and ad-hoc backups. These MUST
# stay untracked: a tracked -wal/-shm gets overwritten by `git reset --hard`
# during deploy, which desyncs/corrupts the live database (can drop committed
# rows still resident in the WAL).
*.db
*.db-wal
*.db-shm
*.db.bak*

# Environment files (may hold secrets/tokens) — never commit. Loaded at
# startup as a config layer; process env still overrides file values.
# Templates are kept tracked: *.env.example / *.env.template do not match *.env.
.env
*.env
!*.env.example
!*.env.template

# Logs
logs/*.log

# Config secrets (but keep templates). Profile files (config.<name>.yaml) are
# intentionally NOT ignored: they hold reproducible, non-secret overrides and
# must survive CI/CD git resets. Secrets belong in *.env files (above).
config/exchanges.yaml
config/email.yaml

# OS
.DS_Store
Thumbs.db

# Build outputs
frontend/dist/
.aider*
